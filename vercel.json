{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "projeto/src/renderer/views/index.html" },
    { "source": "/views/(.*)", "destination": "projeto/src/renderer/views/$1" },
    { "source": "/js/(.*)", "destination": "projeto/src/renderer/js/$1" },
    { "source": "/css/(.*)", "destination": "projeto/src/renderer/css/$1" },
    { "source": "/home.html", "destination": "projeto/src/renderer/views/home.html" },
    { "source": "/estoque.html", "destination": "projeto/src/renderer/views/estoque.html" },
    { "source": "/pagcadastro.html", "destination": "projeto/src/renderer/views/pagcadastro.html" },
    { "source": "/index.html", "destination": "projeto/src/renderer/views/index.html" }
  ]
}
