{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "src/renderer/views/index.html" },
    { "source": "/views/(.*)", "destination": "src/renderer/views/$1" },
    { "source": "/js/(.*)", "destination": "src/renderer/js/$1" },
    { "source": "/css/(.*)", "destination": "src/renderer/css/$1" }
  ]
}
